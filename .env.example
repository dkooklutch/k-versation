# Public application URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase database and storage
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Host authentication. Never put a raw password here.
# Format: scrypt$<random-salt>$<64-character-derived-key>
HOST_PASSWORD_HASH=
SESSION_SECRET=

# Transactional email
RESEND_API_KEY=
RESEND_FROM_EMAIL=K-VERSATION <updates@your-verified-domain.com>
HOST_NOTIFICATION_EMAIL=thekversation@gmail.com
